.cart-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 购物车列表 - 可滚动区域 */
.cart-list {
  flex: 1;
  height: 0;
  padding: 32rpx;
  box-sizing: border-box;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.cart-item.removing {
  opacity: 0;
  transform: translateX(-100rpx);
}

.item-icon {
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.item-thumb {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.item-brand {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

.item-price {
  font-size: 24rpx;
  color: #333;
  margin-top: 8rpx;
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ccc;
  border-radius: 50%;
}

.item-delete:active {
  background: #f0f0f0;
  color: #999;
}

/* 底部 */
.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.purchase-btn {
  width: 100%;
  background: #1a1a1a;
  color: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.purchase-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.purchase-btn.purchasing {
  background: #4caf50;
}

.item-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  margin-bottom: 0;
}