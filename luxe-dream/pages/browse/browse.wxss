.browse-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: #ffffff;
}

/* 品类指示器 */
.category-indicator {
  position: absolute;
  top: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  opacity: 0.6;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.category-indicator.fade-in {
  animation: fadeInUp 0.4s ease-out;
}

.category-icon {
  font-size: 32rpx;
}

.category-name {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 2rpx;
}

/* 品牌名区域 */
.brand-area {
  position: absolute;
  top: 160rpx;
  left: 0;
  right: 0;
text-align: center;
}

/* 商品主体区域 */
.product-area {
  width: 100%;
  height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.product-image-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.product-image-wrap.slide-left {
  animation: slideOutLeft 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.product-image-wrap.slide-right {
  animation: slideOutRight 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.product-image-wrap.slide-in {
  animation: slideIn 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.product-image {
  width: 500rpx;
  height: 500rpx;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

/* 商品信息 */
.product-info {
  position: absolute;
  bottom: 200rpx;
  left: 0;
  right: 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 操作栏 */
.action-bar {
  position: absolute;
  bottom: 100rpx;
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.btn-icon {
  font-size: 36rpx;
}

.cart-btn:active {
  transform: scale(0.85);
  border-color: #333;
}

/* 滑动提示 - 底部浮层，不遮挡主内容 */
.swipe-hint {
  position: fixed;
  bottom: 180rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 100;
  transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  pointer-events: auto;
}

.swipe-hint.hidden {
  opacity: 0;
  transform: translateY(40rpx);
  pointer-events: none;
}

.hint-content {
  background: rgba(0, 0, 0, 0.7);
  border-radius: 20rpx;
  padding: 28rpx 36rpx;
  text-align: center;
  backdrop-filter: blur(10px);
}

.hint-horizontal {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.hint-vertical {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.hint-dismiss {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  pointer-events: none;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* 动画 */
@keyframes slideOutLeft {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-200rpx); opacity: 0; }
}

@keyframes slideOutRight {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(200rpx); opacity: 0; }
}

@keyframes slideIn {
  from { transform: translateX(0); opacity: 0; transform: scale(0.9); }
  to { transform: translateX(0); opacity: 1; transform: scale(1); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateX(-50%) translateY(20rpx); }
  to { opacity: 0.6; transform: translateX(-50%) translateY(0); }
}