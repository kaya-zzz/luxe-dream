/* 全局样式 - Luxe Dream */

page {
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
  color: #1a1a1a;
  overflow: hidden;
}

/* 品牌名文字样式 */
.brand-text {
  font-size: 22rpx;
  color: #bbbbbb;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  font-weight: 300;
}

/* 商品名样式 */
.product-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.3;
}

/* 商品描述 */
.product-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 价格样式 */
.product-price {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-top: 12rpx;
}

/* 圆形按钮 */
.circle-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.circle-btn:active {
  transform: scale(0.9);
  background: #f5f5f5;
}